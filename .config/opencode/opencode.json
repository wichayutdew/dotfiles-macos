{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "enabled_providers": [
    "anthropic-gateway",
    "openai-gateway"
  ],
  "provider": {
    "anthropic-gateway": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Anthropic Gateway",
      "options": {
        "baseURL": "{env:AI_GATEWAY_URL}",
        "apiKey": "{env:GENAI_API_KEY}"
      },
      "models": {
        "claude-sonnet-5": {
          "name": "claude-sonnet-5",
          "limit": {
            "context": 200000,
            "output": 200000
          }
        },
        "claude-haiku-4.5": {
          "name": "claude-haiku-4.5",
          "limit": {
            "context": 200000,
            "output": 200000
          }
        },
        "claude-opus-4-8": {
          "name": "claude-opus-4-8",
          "limit": {
            "context": 200000,
            "output": 200000
          }
        }
      }
    },
    "openai-gateway": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI Gateway",
      "options": {
        "baseURL": "{env:AI_GATEWAY_URL}",
        "apiKey": "{env:GENAI_API_KEY}"
      },
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4",
          "limit": {
            "context": 200000,
            "output": 200000
          }
        },
        "gpt-5.3-codex": {
          "name": "gpt-5.3-codex",
          "limit": {
            "context": 200000,
            "output": 200000
          }
        }
      }
    }
  },
  "model": "anthropic-gateway/claude-sonnet-5",
  "small_model": "openai-gateway/gpt-5.4",
  "default_agent": "developer",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true,
      "oauth": {}
    },
    "gitlab": {
      "type": "remote",
      "url": "{env:GITLAB_MCP}",
      "enabled": true,
      "oauth": {}
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true,
      "oauth": {
        "clientId": "{env:FIGMA_CLIENT_ID}",
        "clientSecret": "{env:FIGMA_CLIENT_SECRET}"
      }
    },
    "custom_skills": {
      "type": "remote",
      "url": "{env:CUSTOM_SKILLS_MCP}",
      "enabled": true,
      "headers": {
        "X-Skills-Version": "{env:CUSTOM_SKILLS_VERSION}"
      }
    },
    "glean": {
      "type": "remote",
      "url": "{env:GLEAN_MCP}",
      "enabled": true,
      "oauth": {}
    },
    "sourcegraph": {
      "type": "remote",
      "url": "{env:SOURCEGRAPH_MCP}",
      "enabled": true,
      "headers": {
        "Authorization": "token {env:SOURCEGRAPH_TOKEN}"
      }
    },
    "grafana": {
      "type": "remote",
      "url": "{env:GRAFANA_MCP}"
    },
    "slack": {
      "type": "remote",
      "url": "{env:SLACK_MCP}"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "superset": {
      "type": "remote",
      "url": "{env:SUPERSET_MCP}"
    }
  },
  "permission": {
    "skill": {
      "*": "ask"
    }
  },
  "skills": {
    "paths": [
      "~/.agents/skills"
    ]
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      ".next/**",
      "build/**",
      "target/**"
    ]
  }
}

# ignore everything
/*

# except these directories
!/.config
/.config/github-copilot
/.config/raycast
/.config/jgit
/.config/karabiner
!/notes
!/.1password
!/.agents
!AGENTS.md

# except these files
!.asdfrc
!.zshrc
!.gitignore
!.gitconfig
!.ideavimrc
!README.md
!Brewfile

# pi coding agent config
!/.pi

# pi secrets
/.pi/agent/auth.json

# pi runtime / cache / memory
/.pi/agent/sessions/
/.pi/agent/logs/
/.pi/logs/
/.pi/agent/bin/
/.pi/agent/**/*.jsonl
/.pi/agent/**/node_modules/
/.pi/agent/**/.cache/
/.pi/agent/**/mcp-cache.json
/.pi/agent/**/mcp-oauth
/.pi/agent/git/github.com/obra/superpowers/

# opencode runtime / cache
/.config/opencode/**/.cache/
/.config/opencode/**/mcp-cache.json
/.config/opencode/**/mcp-oauth

# ignore RUST specific files
.config/cargo/*
!.config/cargo/config.toml
!.config/cargo/.gitignore

# ignore GitHub CLI authentication files
.config/gh/hosts.yml

# ignore fish environment file
.config/fish/conf.d/environment.fish
.config/fish/fish_variables

{
  "lastChangelogVersion": "0.80.3",
  "defaultProvider": "anthropic-gateway",
  "defaultModel": "claude-sonnet-5",
  "packages": [
    "npm:@bitcraft-apps/pi-web-tools",
    "npm:pi-research",
    "npm:pi-mcp-adapter",
    {
      "source": "npm:@plannotator/pi-extension",
      "skills": []
    },
    "npm:pi-subagents",
    "git:github.com/obra/superpowers"
  ],
  "theme": "light/dark",
  "terminal": {
    "showTerminalProgress": true
  },
  "doubleEscapeAction": "tree",
  "treeFilterMode": "default",
  "defaultThinkingLevel": "high",
  "skills": [
    "~/.agents/skills"
  ],
  "subagents": {
    "agentOverrides": {
      "architecture-designer": {
        "model": "anthropic-gateway/claude-opus-4-8"
      },
      "code-reviewer": {
        "model": "anthropic-gateway/claude-opus-4-8"
      },
      "debugger": {
        "model": "anthropic-gateway/claude-opus-4-8"
      },
      "developer": {
        "model": "openai-gateway/gpt-5.4"
      },
      "documentation-writer": {
        "model": "anthropic-gateway/claude-sonnet-5"
      },
      "explore": {
        "model": "anthropic-gateway/claude-sonnet-5"
      },
      "mr-creator": {
        "model": "openai-gateway/gpt-5.4"
      },
      "plan": {
        "model": "anthropic-gateway/claude-opus-4-8"
      },
      "quality-checker": {
        "model": "openai-gateway/gpt-5.4"
      },
      "skill-writer": {
        "model": "anthropic-gateway/claude-sonnet-5"
      },
      "test-automation-engineer": {
        "model": "openai-gateway/gpt-5.4"
      }
    }
  }
}

  },
  "footerSegments": {
    "gitCounts": true,
    "sessionDuration": true,
    "username": false,
    "time": true,
    "cwd": true,
    "gitBranch": true,
    "os": true,
    "runtime": true,
    "context": true,
    "tokens": true,
    "cost": true,
    "packageVersion": true,
    "gitCommit": true,
    "gitMetrics": true
  },
  "extensionStatuses": {
    "placements": {
      "mcp": "middle"
    },
    "colorModes": {
      "mcp": "zentui"
    }
  }

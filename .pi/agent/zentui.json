    "starship": "terminal",
    "editor": "terminal",
    "userMessages": "terminal"
  },
  "features": {
    "copyFriendly": true
  },
  "fixedEditor": {
    "enabled": true
  },
  "contextStyle": "text+gauge",
  "separator": "chevron",
  "pathDisplay": {

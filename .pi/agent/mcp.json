{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "directTools": true
    },
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/mcp",
      "auth": "oauth"
    },
    "gitlab": {
      "url": "${GITLAB_MCP}",
      "auth": "oauth"
    },
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "auth": "oauth",
      "oauth": {
        "clientId": "${FIGMA_CLIENT_ID}",
        "clientSecret": "${FIGMA_CLIENT_SECRET}"
      }
    },
    "agoda_skills": {
      "url": "${AGODA_SKILLS_MCP}",
      "headers": {
        "X-Agoda-Skills-Version": "20260224.0.0"
      }
    },
    "glean": {
      "url": "${GLEAN_MCP}",
      "auth": "oauth"
    },
    "sourcegraph": {
      "url": "${SOURCEGRAPH_MCP}",
      "headers": {
        "Authorization": "token ${SOURCEGRAPH_TOKEN}"
      }
    },
    "grafana": {
      "url": "${GRAFANA_MCP}"
    },
    "slack": {
      "url": "${SLACK_MCP}"
    },
    "gh_grep": {
      "url": "https://mcp.grep.app",
      "directTools": true
    },
    "superset": {
      "url": "${SUPERSET_MCP}"
    }
  }
}
